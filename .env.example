# ============================================================
# ERP REALNET - Contoh file .env
# Salin file ini jadi ".env" (tanpa .example) lalu isi nilai asli.
# File ".env" TIDAK ikut ke Git (sudah ada di .gitignore) --
# supaya kredensial tidak pernah ter-push ke GitHub.
# ============================================================

# --- Database (satu database gabungan: erprealnet) ---
DB_HOST=localhost
DB_NAME=u272457353_erprealnet
DB_USER=isi_username_mysql_disini
DB_PASS=isi_password_mysql_disini

# --- WhatsApp API (Starsender) ---
WA_API_URL=https://api.starsender.online/api/send
WA_API_TOKEN_CUSTOMER=isi_token_customer_disini
WA_API_TOKEN_GROUP=isi_token_group_disini

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=isi_api_key_disini

# --- Tripay ---
TRIPAY_API_KEY=isi_disini
TRIPAY_PRIVATE_KEY=isi_disini
TRIPAY_MERCHANT_CODE=isi_disini
TRIPAY_BASE_URL=https://tripay.co.id/api

# --- URL Shortener ---
SHORTENER_BASE_URL=https://api.tinyurl.com
SHORTENER_API_KEY=isi_disini
