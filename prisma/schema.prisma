// ============================================================
// ERP REALNET -- Prisma schema untuk database `erprealnet`
// Model di-generate dari consolidated_schema.sql, nama kolom
// dipertahankan sama seperti skema MySQL (pakai @map/@@map)
// supaya cocok dengan data yang sudah ada.
// ============================================================

generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
  moduleFormat = "esm"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// AUTO-GENERATED dari consolidated_schema.sql -- review manual disarankan untuk enum & relasi lanjutan

model JaringanPop {
  id Int @id @default(autoincrement())
  name String @db.VarChar(255)
  @@map("jaringan_pop")
}

model JaringanOdp {
  ODP_ID String @id @db.VarChar(255)
  Nama_ODP String? @db.VarChar(255)
  Lokasi String? @db.Text
  Kapasitas_Port Int?
  Kapasitas_Terpakai Int?
  Status String? @db.VarChar(50)
  Tanggal_Instalasi DateTime? @db.Date
  Latitude Decimal? @db.Decimal(10, 8)
  Longitude Decimal? @db.Decimal(11, 8)
  Redaman_Output Decimal? @db.Decimal(5, 2)
  Nama_POP String? @db.VarChar(255)
  @@map("jaringan_odp")
}

