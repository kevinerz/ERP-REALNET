// Tiket cabut modem (cabut.php). Tabel ini SEBELUMNYA hidup di database
// terpisah yang belum ikut konsolidasi (u272457353_cabut) -- sekarang
// dipindahkan ke database utama erprealnet (mulai dari kosong, data lama
// di database terpisah TIDAK dimigrasikan, sesuai keputusan user).
// Nilai `pop` sengaja dipertahankan PascalCase ("Rajeg"/"Mauk"/"Kemeri")
// sama seperti pilihan dropdown di cabut.php lama, supaya cabut.php yang
// masih dipertahankan (hanya dialihkan koneksi DB-nya) tidak perlu diubah
// logic-nya sama sekali.
model TiketCabutModem {
  id Int @id @default(autoincrement())
  pop String @db.VarChar(20)
  nama String @db.VarChar(255)
  alamat String @db.Text
  wa String @db.VarChar(20)
  alasan String @db.Text
  sn_modem String @db.VarChar(100)
  status String @default("belum selesai") @db.VarChar(20)
  created_at DateTime? @db.Timestamp(0)
  @@map("tickets_cabut_modem")
}

