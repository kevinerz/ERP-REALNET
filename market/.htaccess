RewriteEngine On

# 1. Redirect Eksternal (Mengubah URL di browser)
# Jika user mengetik file.php, otomatis diubah menjadi file (tanpa .php)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Rewrite Internal (Agar server mengenali file)
# Jika user akses file tanpa ekstensi, server akan memanggil file .php aslinya
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]