# Salin jadi .env.local untuk development lokal.
# Di Hostinger, isi variabel yang sama lewat menu Environment Variables
# pada dashboard Node.js App (bukan file ini).

# Koneksi ke database erprealnet yang sudah dikonsolidasi
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/u272457353_erprealnet"

# Kunci rahasia untuk menandatangani cookie sesi login (HMAC).
# Wajib diisi string acak panjang & unik, JANGAN dipakai ulang dari project lain.
# Generate contoh: openssl rand -base64 32
AUTH_SECRET="ganti-dengan-string-acak-panjang"
